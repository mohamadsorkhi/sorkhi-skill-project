/vendor
/node_modules
/public/hot
/public/storage
storage/*.key
.env
.phpunit.result.cache
npm-debug.log
yarn-error.log

# Ignored specific files inside storage but keeps the folders
# (This assumes you have standard Laravel structure)
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/views/*
/storage/framework/testing/*
/storage/logs/*.log
!/storage/logs/.gitignore

# IDE & Editor files (Important for PhpStorm)
.idea
.vscode
*.sublime-project
*.sublime-workspace

# System files
.DS_Store
Thumbs.db

*.zip
